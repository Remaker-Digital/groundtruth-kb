{% comment %}
  Agent Red Customer Experience — Chat Widget (App Embed Block)

  Shopify Theme App Extension that embeds the Agent Red chat widget
  on the merchant's storefront. Configured via the Shopify theme editor
  under Online Store > Themes > Customize > App embeds.

  Architecture (Decision UI-2):
    - App embed block with target: "body" (renders at document level)
    - Widget bundle loaded from the Agent Red API gateway (always current)
    - Publishable widget key for client-side auth (Decision UI-6)
    - Shadow DOM launcher + iframe panel (Decision UI-3)

  Merchant activation:
    1. Install the Agent Red app
    2. Go to Online Store > Themes > Customize
    3. Click App embeds in the sidebar
    4. Toggle "Agent Red Chat" on
    5. Enter the widget key and API URL from the Agent Red dashboard
    6. Save
    7. Configure appearance and behavior in the Agent Red dashboard

  (c) 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.
{% endcomment %}

{% if block.settings.widget_key != blank %}
  <script
    src="{{ block.settings.api_url }}/widget.js"
    defer
    data-widget-key="{{ block.settings.widget_key }}"
    data-api-url="{{ block.settings.api_url }}"
    {% comment %} Page context for quick action template variables (WI #228b) {% endcomment %}
    data-page-type="{{ template.name | default: 'other' }}"
    {% if product %}
      data-page-handle="{{ product.handle }}"
      data-product-title="{{ product.title | escape }}"
    {% elsif collection %}
      data-page-handle="{{ collection.handle }}"
      data-collection-title="{{ collection.title | escape }}"
    {% elsif page %}
      data-page-handle="{{ page.handle }}"
    {% elsif blog %}
      data-page-handle="{{ blog.handle }}"
    {% endif %}
    {% comment %} Shopify customer identity passthrough (AUTH-4) {% endcomment %}
    {% if customer and block.settings.identity_secret != blank %}
      data-shopify-customer-id="{{ customer.id }}"
      data-shopify-customer-email="{{ customer.email | escape }}"
      data-shopify-customer-name="{{ customer.first_name | escape }} {{ customer.last_name | escape }}"
      data-shopify-customer-hmac="{{ customer.id | hmac_sha256: block.settings.identity_secret }}"
    {% endif %}
  ></script>
{% endif %}

{% schema %}
{
  "name": "Agent Red Chat",
  "target": "body",
  "enabled_on": {
    "templates": ["*"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Connection"
    },
    {
      "type": "text",
      "id": "widget_key",
      "label": "Widget Key",
      "info": "Your publishable widget key from the Agent Red dashboard (starts with pk_live_)"
    },
    {
      "type": "text",
      "id": "api_url",
      "label": "API URL",
      "info": "Paste from your Agent Red dashboard → Widget Configuration → API URL"
    },
    {
      "type": "text",
      "id": "identity_secret",
      "label": "Customer Identity Secret",
      "info": "Paste from Agent Red dashboard → Settings → Security. Enables automatic identification of logged-in Shopify customers (skips verification form)."
    },
    {
      "type": "header",
      "content": "Chat Configuration"
    },
    {
      "type": "paragraph",
      "content": "Widget appearance and behavior are configured in the Agent Red dashboard. Open your dashboard and navigate to Widget Configuration to customize colors, position, greeting, and more."
    }
  ]
}
{% endschema %}
