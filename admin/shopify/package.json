{
  "name": "@agent-red/admin-shopify",
  "version": "1.0.0",
  "private": true,
  "description": "Agent Red Customer Experience — Shopify embedded admin (Polaris + App Bridge)",
  "type": "module",
  "scripts": {
    "sync-env": "powershell -ExecutionPolicy Bypass -File ../../scripts/sync-admin-env.ps1",
    "predev": "npm run sync-env",
    "dev": "vite",
    "prebuild": "npm run sync-env",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@shopify/polaris": "^12.27.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@mantine/core": "^8.3.15",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
