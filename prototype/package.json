{
  "name": "agent-red-admin-prototype",
  "version": "1.0.0",
  "private": true,
  "description": "Agent Red Customer Experience - Admin Dashboard Prototype (Mantine + Polaris)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "build:capture-runner": "esbuild scripts/dom-to-svg-runner.js --bundle --format=iife --outfile=scripts/dom-to-svg-browser.js --platform=browser",
    "capture-to-svg": "npm run build:capture-runner && node scripts/capture-page-to-svg.js"
  },
  "dependencies": {
    "@mantine/charts": "^7.17.0",
    "@mantine/core": "^7.17.0",
    "@mantine/dates": "^7.17.0",
    "@mantine/form": "^7.17.0",
    "@mantine/hooks": "^7.17.0",
    "@mantine/notifications": "^7.17.0",
    "@shopify/polaris": "^12.27.0",
    "@shopify/polaris-icons": "^9.3.1",
    "dayjs": "^1.11.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "dom-to-svg": "^0.12.2",
    "puppeteer": "^23.11.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.0"
  }
}
