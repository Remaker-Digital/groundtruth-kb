{
  "specs": [
    {
      "id": "SPEC-1534",
      "title": "AGNTCY SDK Mandatory for All Agent Communication",
      "status": "specified",
      "changed_by": "S120",
      "change_reason": "Owner directive: AGNTCY SDK is mandatory, no relaxations",
      "description": "AGNTCY SDK (agntcy-app-sdk) is the mandatory foundation for all agent communication, transport creation, and protocol client creation in Agent Red. No direct SDK bypass, relaxation, or opt-out is permitted.",
      "section": "AGNTCY",
      "type": "governance",
      "assertions": [
        {
          "type": "grep",
          "description": "AgntcyFactory is the sole factory for transport and protocol client creation",
          "query": "AgntcyFactory",
          "target": "src/multi_tenant/agntcy_sdk_integration.py",
          "expected": "match"
        },
        {
          "type": "grep",
          "description": "mcp_client.py uses create_mcp_client from agntcy_sdk_integration",
          "query": "create_mcp_client",
          "target": "src/multi_tenant/mcp_client.py",
          "expected": "match"
        },
        {
          "type": "grep",
          "description": "No relaxation/bypass language in adoption procedure",
          "query": "relaxation",
          "target": "docs/operations/agntcy-platform-adoption-procedure.md",
          "expected": "no_match"
        },
        {
          "type": "grep",
          "description": "USE_AGENT_CONTAINERS default is true",
          "query": "true",
          "target": "src/chat/pipeline/constants.py",
          "expected": "match"
        }
      ]
    },
