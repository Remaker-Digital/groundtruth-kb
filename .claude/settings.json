{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Project-level harness settings. This file is TRACKED in git (negated by .gitignore) so every worktree and fresh clone inherits the bridge visibility hook. Workstation-specific permissions live in settings.local.json which remains untracked. Do not remove the poller-freshness UserPromptSubmit hook registration without reading .claude/rules/bridge-essential.md first.",
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/formal-artifact-approval-gate.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/scripts/session_self_initialization.py\" --emit-report --fast-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/scripts/session_self_initialization.py\" --emit-wrapup --fast-hook",
            "timeout": 15
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \"$CLAUDE_PROJECT_DIR/.claude/hooks/poller-freshness.py\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
