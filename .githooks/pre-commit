#!/usr/bin/env bash
# Pre-commit hook: redacted secret scan plus PowerShell syntax validation.
# Delegates to .githooks/pre-commit-ps1-parse.ps1 when PS1 files are staged.
#
# Activation (one-time, per developer):
#   git config core.hooksPath .githooks
#
# © 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.

set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
PYTHON_BIN="${PYTHON:-python}"

"$PYTHON_BIN" -m groundtruth_kb secrets scan \
    --staged \
    --redacted \
    --fail-on verified-provider || exit $?

"$PYTHON_BIN" scripts/check_dev_environment_inventory_drift.py \
    --staged \
    --allow-review-evidence || exit $?

# Only proceed if PowerShell is available
PWSH=""
if command -v pwsh &>/dev/null; then
    PWSH="pwsh"
elif command -v powershell.exe &>/dev/null; then
    PWSH="powershell.exe"
else
    # PowerShell not available (non-Windows environment) — skip gracefully
    exit 0
fi

# Only proceed if any staged files are .ps1
STAGED_PS1=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep -c '\.ps1$' || true)
if [ "$STAGED_PS1" -eq 0 ]; then
    exit 0
fi

"$PWSH" -NoProfile -ExecutionPolicy Bypass \
    -File "$REPO_ROOT/.githooks/pre-commit-ps1-parse.ps1" || exit 1
