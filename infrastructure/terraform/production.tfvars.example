# Agent Red Customer Engagement — Production Terraform Variables
#
# Copy to production.tfvars and fill in values:
#   cp production.tfvars.example production.tfvars
#
# IMPORTANT: Never commit production.tfvars — it contains sensitive values.
# The .gitignore should exclude *.tfvars files.
#
# © 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.

# Azure subscription
subscription_id = "YOUR_SUBSCRIPTION_ID"

# Resource group (existing)
resource_group_name = "agntcy-prod-rg"
location            = "eastus2"
environment         = "production"

# Container Registry (existing)
container_registry = "acragntcycsprodrc6vcp.azurecr.io"

# Container App Environment
container_app_environment_name = "agent-red-cae"

# Network — subnet must be delegated to Microsoft.App/environments
container_apps_subnet_id = "/subscriptions/YOUR_SUB/resourceGroups/agntcy-prod-rg/providers/Microsoft.Network/virtualNetworks/agntcy-cs-prod-vnet/subnets/container-apps"

# NATS (internal VNet address)
nats_url = "nats://10.0.1.5:4222"

# Cosmos DB (existing)
cosmos_db_endpoint      = "https://cosmos-agntcy-cs-prod-rc6vcp.documents.azure.com:443/"
cosmos_db_database      = "agent-red-prod"
cosmos_db_account_name  = "cosmos-agntcy-cs-prod-rc6vcp"
manage_cosmos_db_account = false # Set true only for fresh deployments

# Customer-Managed Keys (Decision #20 — enable after Key Vault RBAC is configured)
enable_cmk = false

# Data archival (Decision #18 — Warm/Cold blob storage)
enable_archival_storage       = false
archival_storage_account_name = "agentredarchival"

# Key Vault (existing)
key_vault_url = "https://kv-agntcy-cs-prod-rc6vcp.vault.azure.net/"

# Application Insights (sensitive — set via TF_VAR_appinsights_connection_string env var)
# appinsights_connection_string = "InstrumentationKey=...;IngestionEndpoint=..."

# Tags
tags = {
  project     = "agent-red"
  owner       = "remaker-digital"
  environment = "production"
  managed_by  = "terraform"
}
