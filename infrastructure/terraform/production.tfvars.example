# Agent Red Customer Experience — Production Terraform Variables
#
# Copy to production.tfvars and fill in values:
#   cp production.tfvars.example production.tfvars
#
# IMPORTANT: Never commit production.tfvars — it contains sensitive values.
# The .gitignore should exclude *.tfvars files.
#
# © 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.

# Azure subscription
subscription_id = "4dce2122-690a-4654-b531-cc647db62331"

# Resource group (Agent Red dedicated)
resource_group_name = "Agent-Red"
location            = "eastus"
environment         = "production"

# Container Registry (Agent Red dedicated)
container_registry = "acragentredeastus.azurecr.io"

# Container App Environment
container_app_environment_name = "agent-red-env"

# Network — subnet must be delegated to Microsoft.App/environments
container_apps_subnet_id = "/subscriptions/4dce2122-690a-4654-b531-cc647db62331/resourceGroups/Agent-Red/providers/Microsoft.Network/virtualNetworks/agentred-prod-vnet/subnets/container-apps"

# Azure OpenAI
azure_openai_endpoint = "https://agent-red-openai.openai.azure.com/"

# NATS (internal Container App FQDN — updated after first deployment)
nats_url                  = "nats://agent-red-nats.internal:4222"
nats_monitoring_endpoint  = "agent-red-nats.internal:8222"

# Cosmos DB (Agent Red dedicated — already provisioned)
cosmos_db_endpoint      = "https://cosmos-agentred-eastus.documents.azure.com:443/"
cosmos_db_database      = "agentred"
cosmos_db_account_name  = "cosmos-agentred-eastus"
manage_cosmos_db_account = false # Set true only for fresh deployments

# Customer-Managed Keys (Decision #20 — enable after Key Vault RBAC is configured)
enable_cmk = false

# Data archival (Decision #18 — Warm/Cold blob storage)
enable_archival_storage       = false
archival_storage_account_name = "agentredarchival"

# Key Vault (Agent Red dedicated — already provisioned)
key_vault_url = "https://kv-agentred-eastus.vault.azure.net/"

# Monitoring alerts
alert_email = "mike@remakerdigital.com"

# Application Insights (sensitive — set via TF_VAR_appinsights_connection_string env var)
# appinsights_connection_string = "InstrumentationKey=...;IngestionEndpoint=..."

# Tags
tags = {
  project     = "agent-red"
  owner       = "remaker-digital"
  environment = "production"
  managed_by  = "terraform"
}
