  "schema_version": 1,
  "db_redaction": [
    {
      "name": "api_key",
      "pattern": "(?:api[_-]?key|apikey)\\s*[:=]\\s*['\\\"]?[\\w\\-]{16,}['\\\"]?",
      "flags": "IGNORECASE"
    },
    {
      "name": "bearer_header",
      "pattern": "(?:Authorization\\s*:\\s*)?Bearer\\s+[\\w\\-\\.~+/]+=*",
      "flags": "IGNORECASE"
    },
    {
      "name": "token",
      "pattern": "(?:token|bearer)\\s*[:=]\\s*['\\\"]?[\\w\\-\\.]{20,}['\\\"]?",
      "flags": "IGNORECASE"
    },
    {
      "name": "secret",
      "pattern": "(?:secret|password|passwd)\\s*[:=]\\s*['\\\"]?[^\\s'\\\"]{8,}['\\\"]?",
      "flags": "IGNORECASE"
    },
    {
