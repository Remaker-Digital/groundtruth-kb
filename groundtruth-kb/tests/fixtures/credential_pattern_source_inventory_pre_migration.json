  "bash_credential": [
    {
      "description": "AWS access key ID (AKIA...)",
      "pattern": "AKIA[0-9A-Z]{16}",
      "flags": ""
    },
    {
      "description": "Anthropic API key (sk-ant-api...)",
      "pattern": "\\bsk-ant-api[0-9]{2}-[a-zA-Z0-9_-]+",
      "flags": ""
    },
    {
      "description": "Secret key (sk-...)",
      "pattern": "\\bsk-[a-zA-Z0-9]{20,}",
      "flags": ""
    },
    {
      "description": "Stripe live secret key",
      "pattern": "\\bsk_live_[a-zA-Z0-9]+",
      "flags": ""
    },
    {
      "description": "Stripe test secret key",
      "pattern": "\\bsk_test_[a-zA-Z0-9]+",
      "flags": ""
    },
    {
      "description": "Stripe restricted key",
      "pattern": "\\brk_live_[a-zA-Z0-9]+",
      "flags": ""
    },
