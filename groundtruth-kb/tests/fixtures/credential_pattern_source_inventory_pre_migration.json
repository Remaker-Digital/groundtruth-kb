      "pattern": "(?:ghp|gho|ghs|ghr)_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}",
      "flags": "IGNORECASE"
    },
    {
      "name": "service_key",
      "pattern": "(?:sk|pk)[-_](?:live|test|prod)[-_][A-Za-z0-9]{20,}",
      "flags": "IGNORECASE"
    },
