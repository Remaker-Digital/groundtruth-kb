      "pattern": "-----BEGIN\\s+(RSA\\s+)?PRIVATE\\s+KEY-----",
      "flags": ""
    },
    {
      "description": "OpenSSH private key",
      "pattern": "-----BEGIN\\s+OPENSSH\\s+PRIVATE\\s+KEY-----",
      "flags": ""
    },
    {
      "description": "Connection string assignment",
      "pattern": "[Cc]onnection[Ss]tring\\s*=\\s*['\\\"]?[^\\s;]+",
      "flags": ""
    },
    {
      "description": "Azure Storage account key",
      "pattern": "AccountKey=[a-zA-Z0-9+/=]{20,}",
      "flags": ""
    },
    {
      "description": "JWT / bearer token",
      "pattern": "\\beyJ[a-zA-Z0-9_-]{50,}",
      "flags": ""
    },
    {
      "description": "Password passed as command argument",
      "pattern": "--password\\s*[=\\s]\\s*\\S+",
      "flags": ""
    },
    {
      "description": "Possible password flag (-p)",
      "pattern": "-p\\s+['\\\"]?[^\\s]+['\\\"]?\\s",
      "flags": ""
    }
  ],
  "bash_output": [
    {
      "description": "Credential value piped or redirected to output",
      "pattern": "(echo|printf|cat)\\s+.*(AKIA|sk-|sk_live|sk_test|-----BEGIN|[Cc]onnection[Ss]tring|AccountKey).*[>|]",
      "flags": "DOTALL"
    },
    {
      "description": "Credential exported as environment variable with literal value",
      "pattern": "(export|set)\\s+\\w*(KEY|SECRET|TOKEN|PASSWORD|CREDENTIAL)\\w*\\s*=\\s*\\S+",
      "flags": "IGNORECASE"
    }
