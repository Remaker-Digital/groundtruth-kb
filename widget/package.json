{
  "name": "@agent-red/widget",
  "version": "1.0.0",
  "private": true,
  "description": "Agent Red Customer Experience — Chat widget (Preact + TypeScript)",
  "type": "module",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "vitest run",
    "test:watch": "vitest",
    "chromatic": "chromatic --exit-zero-on-changes"
  },
  "dependencies": {
    "preact": "^10.25.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^16.3.0",
    "@preact/preset-vite": "^2.9.0",
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/preact-vite": "^8.6.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/preact": "^3.2.4",
    "chromatic": "^16.2.0",
    "happy-dom": "^20.8.9",
    "storybook": "^8.6.0",
    "terser": "^5.46.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
