{
  "name": "@agent-red/admin-provider",
  "version": "1.0.0",
  "private": true,
  "description": "Agent Red Customer Experience — Provider admin console (platform operator / SPA)",
  "type": "module",
  "engines": {
    "node": ">=20.0"
  },
  "scripts": {
    "sync-env": "powershell -ExecutionPolicy Bypass -File ../../scripts/sync-admin-env.ps1",
    "predev": "npm run sync-env",
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "prebuild": "npm run sync-env",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@mantine/core": "^7.17.0",
    "@mantine/hooks": "^7.17.0",
    "@mantine/notifications": "^7.17.0",
    "dayjs": "^1.11.13",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.15.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  }
}
