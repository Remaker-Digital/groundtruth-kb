# =============================================================================
# AI Assistant
# =============================================================================
# NOTE: we deliberately ignore the CONTENTS of .claude/ (with /*), not the
# directory itself. This is required so that !-negations below can re-include
# specific files. A blanket ".claude/" ignore would shadow all negations.
# Do not collapse these patterns without reading .claude/rules/bridge-essential.md.
#
# Per S307 hardcoded-path directive: workstation-local config such as
# .claude/settings.local.json (Claude permission entries with //e/... paths)
# is intentionally NOT tracked here. The blanket .claude/* ignore covers it
# without needing a separate name-specific rule. Each workstation regenerates
# its own settings.local.json; do not migrate it across machines.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/hooks/*
!.claude/hooks/poller-freshness.py
!.claude/hooks/credential-scan.py
!.claude/hooks/*.py
!.claude/rules/
.claude/rules/*
!.claude/rules/bridge-essential.md
!.claude/rules/*.md
# Dogfood install of canonical-terminology config for GT-KB self-doctor per
# GTKB-GOV-TERM-PRIMER-STARTUP Slice 1 (S327, bridge -015 VERIFIED).
!.claude/rules/canonical-terminology.toml
!.claude/skills/
.claude/skills/*
!.claude/skills/*/
!.claude/skills/*/SKILL.md
!.claude/skills/*/references/
!.claude/skills/*/references/*.md
!.claude/skills/*/scripts/
!.claude/skills/*/scripts/*.py
!.claude/skills/*/helpers/
!.claude/skills/*/helpers/*.py
!.claude/commands/
.claude/commands/*
!.claude/commands/registry.json

.kiro/
cookies.txt

# =============================================================================
# GitHub Wiki (separate repo, not committed to main)
# =============================================================================
agent-red.wiki/
wiki/

# =============================================================================
# Independent Progress Assessments (Cursor-generated, consumed)
# =============================================================================
# NOTE: same pattern as .claude/ above. Ignore the CONTENTS, not the directory,
# so bridge-automation scripts can be re-included via negation.
independent-progress-assessments/*
!independent-progress-assessments/AGENT-RED-GO-STATE-*.md
!independent-progress-assessments/OPERATING-MODEL-DRIFT-INVENTORY-*.md
!independent-progress-assessments/CODEX-INSIGHT-DROPBOX/
independent-progress-assessments/CODEX-INSIGHT-DROPBOX/*
!independent-progress-assessments/CODEX-INSIGHT-DROPBOX/STANDING-BACKLOG-HARVEST-*.md
!independent-progress-assessments/CODEX-INSIGHT-DROPBOX/rehearsal/
independent-progress-assessments/CODEX-INSIGHT-DROPBOX/rehearsal/*
!independent-progress-assessments/CODEX-INSIGHT-DROPBOX/rehearsal/manifest.toml
!independent-progress-assessments/bridge-automation/
independent-progress-assessments/bridge-automation/*
!independent-progress-assessments/bridge-automation/*.ps1
!independent-progress-assessments/bridge-automation/*.vbs
!independent-progress-assessments/bridge-automation/README.md
# Teaching-grade reference docs (e.g. README-ENV-SETUP.md) — tracked so
# adopters can read setup procedures from a fresh checkout. Per S307
# pedagogical commenting directive.
!independent-progress-assessments/bridge-automation/README-*.md
# IPA archive directory — track ONLY the explanatory README.md so adopters
# understand the archive convention. The 6 archived one-shot scripts remain
# untracked (consistent with the IPA blanket-ignore policy). Per
# bridge/gtkb-root-directory-migration-post-verify-009.md Phase 1f.
!independent-progress-assessments/archive/
independent-progress-assessments/archive/*
!independent-progress-assessments/archive/README.md
# Tests for bridge-automation — tracked so CI + pre-commit can exercise the guard.
!independent-progress-assessments/bridge-automation/tests/
!independent-progress-assessments/bridge-automation/tests/*.ps1
# Generated noconsole wrappers — regenerated by run-bridge-scan-noconsole.ps1
independent-progress-assessments/bridge-automation/*.generated.ps1

