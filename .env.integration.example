# Agent Red Integration Testing Environment Template
# 
# Copy this to .env.local and fill in your actual credentials
# NEVER commit .env.local or any file with real credentials!
#
# © 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.

# ---------------------------------------------------------------------------
# Integration Testing Control
# ---------------------------------------------------------------------------
USE_REAL_APIS=true
ENVIRONMENT=integration_testing

# ---------------------------------------------------------------------------
# Stripe Test Mode Configuration
# ---------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key_here

# Get this from: https://dashboard.stripe.com/test/webhooks
# Create webhook endpoint: http://localhost:8080/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ---------------------------------------------------------------------------
# Shopify Partner App Configuration  
# ---------------------------------------------------------------------------
# Get these from: https://partners.shopify.com/organizations/YOUR_ORG/apps/YOUR_APP
SHOPIFY_API_KEY=your_shopify_api_key_here
SHOPIFY_API_SECRET=your_shopify_api_secret_here

# Enable test mode for Shopify billing (recommended)
SHOPIFY_BILLING_TEST=true

# ---------------------------------------------------------------------------
# Application Configuration
# ---------------------------------------------------------------------------
APP_BASE_URL=http://localhost:8080
LOG_LEVEL=DEBUG

# ---------------------------------------------------------------------------
# Optional: Azure Services (can be mocked for integration tests)
# ---------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_key
# USE_AZURE_OPENAI=false

# ---------------------------------------------------------------------------
# Optional: Database (can use in-memory for integration tests)
# ---------------------------------------------------------------------------
# COSMOS_DB_CONNECTION_STRING=AccountEndpoint=https://localhost:8081/;AccountKey=...

# ---------------------------------------------------------------------------
# Optional: Message Queue (can be mocked for integration tests)
# ---------------------------------------------------------------------------
# NATS_URL=nats://localhost:4222

# ---------------------------------------------------------------------------
# Setup Instructions
# ---------------------------------------------------------------------------
# 
# 1. Stripe Setup:
#    - Create account at https://stripe.com
#    - Get test API keys from Dashboard → Developers → API keys
#    - Create webhook endpoint for http://localhost:8080/api/webhooks/stripe
#    - Select these events: checkout.session.completed, customer.subscription.*,
#      invoice.payment_succeeded, invoice.payment_failed, invoice.finalization_failed
#    - Run: python scripts/stripe/create_product_catalog.py
#
# 2. Shopify Setup:
#    - Create Partner account at https://partners.shopify.com
#    - Create new app in Partner Dashboard
#    - Get API key and secret from App setup → App details
#    - Enable billing permissions in App setup → App permissions
#    - Optional: Create development store and install your app
#
# 3. Validation:
#    - Run: python scripts/setup-integration-testing.py
#    - Run: python scripts/run-integration-tests.py config
#
# 4. Full Testing:
#    - Start app: uvicorn src.main:app --reload --port 8080
#    - Run tests: python scripts/run-integration-tests.py
#