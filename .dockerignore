# .dockerignore — Agent Red Customer Experience
# © 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.
#
# Excludes everything not needed inside the production container image.

# Version control
.git
.github
.gitignore

# IDE / editor
.vscode
.idea
.claude

# Auto-generated dependency caches
.codex_pydeps

# Environment files (secrets — never bake into images)
.env
.env.*
.env.local
.env.integration
.env.*.local
.env.example
.env.integration.example

# Python artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
htmlcov
.coverage
# Python dist/build artifacts
build

# Tests (not needed in production image)
tests/
pyproject.toml
requirements-test.txt

# Documentation
docs/
docs-site/
README.md
CLAUDE.md

# Branding / legal / marketing (not runtime dependencies)
branding/
legal/
website/

# Frontend projects (built and served separately)
prototype/
extensions/
# Widget — exclude source, keep dist/ (IIFE bundle served at /widget.js)
widget/src/
widget/node_modules/
widget/package.json
widget/package-lock.json
widget/tsconfig.json
widget/vite.config.ts
widget/dev.html

# Admin: exclude everything EXCEPT admin/{shopify,standalone}/dist/ (pre-built SPA assets)
admin/shared/
admin/node_modules/
admin/package.json
admin/package-lock.json
# Shopify admin — exclude source, keep dist/
admin/shopify/src/
admin/shopify/node_modules/
admin/shopify/package.json
admin/shopify/package-lock.json
admin/shopify/tsconfig.json
admin/shopify/vite.config.ts
admin/shopify/vite-env.d.ts
admin/shopify/index.html
admin/shopify/index.tsx
# Standalone admin — exclude source, keep dist/
admin/standalone/src/
admin/standalone/node_modules/
admin/standalone/package.json
admin/standalone/package-lock.json
admin/standalone/tsconfig.json
admin/standalone/vite.config.ts
admin/standalone/vite-env.d.ts
admin/standalone/index.html
admin/standalone/index.tsx
admin/standalone/login/
admin/standalone/layouts/
admin/standalone/pages/

# Provider admin — exclude source, keep dist/
admin/provider/src/
admin/provider/node_modules/
admin/provider/package.json
admin/provider/package-lock.json
admin/provider/tsconfig.json
admin/provider/vite.config.ts
admin/provider/vite-env.d.ts
admin/provider/index.html
admin/provider/index.tsx
admin/provider/layouts/
admin/provider/pages/

# Node / frontend tooling
node_modules/
package.json
package-lock.json
shopify.app.toml

# Infrastructure as code
infrastructure/
.terraform
*.tfstate
*.tfstate.backup
*.tfvars

# Scripts (setup/deploy tooling, not application code)
scripts/

# Evaluation datasets (not runtime)
evaluation/

# Logs (local test artifacts)
logs/

# Memory (Claude project memory)
memory/

# Independent assessments
independent-progress-assments/

# Wiki
agent-red.wiki/
*.wiki/

# Temporary / local
local/
scratch/
temp/
tmp/
*.log
*.tmp
*.bak

# Sensitive data directories
customer-data/
financial/

# OS artifacts
Thumbs.db
desktop.ini
.DS_Store

# Docker (prevent recursive context)
Dockerfile
docker-compose.yml
docker-compose*.yml
.dockerignore

# Stripe CLI binary
stripe.exe
stripe
