# .dockerignore — Agent Red Customer Experience
# © 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.
#
# Excludes everything not needed inside the production container image.

# Version control
.git
.github
.gitignore

# IDE / editor
.vscode
.idea
.claude

# Auto-generated dependency caches
.codex_pydeps

# Environment files (secrets — never bake into images)
.env
.env.local
.env.integration
.env.*.local
.env.example
.env.integration.example
# Note: .env.staging files under admin/ are NOT excluded — Dockerfile.test
# copies them for tests that verify staging env configuration.

# Python artifacts
__pycache__
*.pyc
*.pyo
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache
htmlcov
.coverage
# Python dist/build artifacts
build

# Tests — included in build context for Dockerfile.test (test host container).
# The production Dockerfile does not COPY these paths, so they are harmless.
# tests/
# pyproject.toml
# requirements-test.txt

# Documentation
docs/
# docs-site/ — kept for production Dockerfile COPY docs-site/docs/
docs-site/node_modules/
docs-site/.cache/
README.md
# CLAUDE.md — not excluded (needed by Dockerfile.test for test_s153 verification)

# Branding / legal / marketing (not runtime dependencies)
branding/
legal/
website/

# Frontend projects (built and served separately)
prototype/
extensions/
# Widget — keep source for Dockerfile.test (test_message_feedback reads .ts files).
# Production Dockerfile does not COPY widget/src/, so this is harmless.
# widget/src/
widget/node_modules/
widget/package.json
widget/package-lock.json
widget/tsconfig.json
widget/vite.config.ts
widget/dev.html

# Admin: keep dist/ bundles for all SPAs + standalone source for Dockerfile.test Vite.
# Exclude node_modules from all admin projects (npm ci runs in-container).
admin/node_modules/
admin/shopify/node_modules/
admin/standalone/node_modules/
admin/standalone/nul
admin/provider/node_modules/
# Shopify admin — exclude source, keep dist/
admin/shopify/src/
admin/shopify/package.json
admin/shopify/package-lock.json
admin/shopify/tsconfig.json
admin/shopify/vite.config.ts
admin/shopify/vite-env.d.ts
admin/shopify/index.html
admin/shopify/index.tsx
# Standalone admin — keep source (Dockerfile.test needs it for Vite dev server).
# Production Dockerfile doesn't COPY these paths, so extra files are harmless.
# Provider admin — keep source (Dockerfile.test needs it for source-inspection tests).
# Production Dockerfile doesn't COPY these paths, so extra files are harmless.
admin/provider/src/
admin/provider/nul

# Node / frontend tooling
node_modules/
package.json
package-lock.json
# shopify.app.toml — kept in context for Dockerfile.test (Shopify compliance tests).

# Infrastructure as code
infrastructure/
.terraform
*.tfstate
*.tfstate.backup
*.tfvars

# Knowledge DB (development-only, not runtime)
tools/knowledge-db/
groundtruth.db
groundtruth.db.backup-*
groundtruth.db.pre-backfill-*
.groundtruth-chroma/

# Scripts — included for Dockerfile.test (test host uses test_pipeline.py).
# scripts/

# Evaluation datasets (not runtime)
evaluation/

# Logs (local test artifacts)
logs/

# Memory (Claude project memory)
memory/

# Independent assessments
# Historic misspelled entry retained for defence-in-depth against stale paths.
independent-progress-assments/
independent-progress-assessments/

# GT-KB governance / runtime surfaces (GTKB-ISOLATION-003 Phase 3 baseline)
.codex/
.groundtruth/
bridge/

# Wiki
agent-red.wiki/
*.wiki/

# Temporary / local
local/
scratch/
temp/
tmp/
*.log
*.tmp
*.bak

# Sensitive data directories
customer-data/
financial/

# OS artifacts
Thumbs.db
desktop.ini
.DS_Store

# Docker (prevent recursive context)
Dockerfile
docker-compose.yml
docker-compose*.yml
.dockerignore

# Stripe CLI binary
stripe.exe
stripe
