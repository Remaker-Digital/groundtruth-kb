# EditorConfig — https://editorconfig.org
# © 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.

root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.py]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{toml,json}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
