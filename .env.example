# Agent Red Customer Experience - Environment Variables Template
# © 2026 Remaker Digital, a DBA of VanDusen & Palmeter, LLC. All rights reserved.
#
#
# IMPORTANT: Never commit .env.local or any file containing real credentials.

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG
# APP_BASE_URL=http://localhost:8080
# APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ---------------------------------------------------------------------------
# Azure OpenAI (optional for local dev - set USE_AZURE_OPENAI=false to skip)
# ---------------------------------------------------------------------------
USE_AZURE_OPENAI=false
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Real API mode (set to false for local dev with mocks)
# ---------------------------------------------------------------------------
USE_REAL_APIS=false

# ---------------------------------------------------------------------------
# NATS JetStream
# ---------------------------------------------------------------------------
NATS_URL=nats://nats:4222

# ---------------------------------------------------------------------------
# Cosmos DB (optional - uncomment cosmosdb in docker-compose.yml first)
# ---------------------------------------------------------------------------
# COSMOS_DB_CONNECTION_STRING=AccountEndpoint=https://localhost:8081/;AccountKey=...

# ---------------------------------------------------------------------------
# Stripe (required for e-commerce / billing)
# ---------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ---------------------------------------------------------------------------
# Langfuse observability (Lane 1 structural export, SPEC-1874)
# Only api-gateway reads these; other containers ignore them.
# ---------------------------------------------------------------------------
LANGFUSE_ENABLED=false
LANGFUSE_HOST=https://us.cloud.langfuse.com
# LANGFUSE_BASE_URL is also accepted (SDK convention)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HASH_SALT=local-dev-salt-change-me

# ---------------------------------------------------------------------------
# Integration API Keys (optional for local dev)
# ---------------------------------------------------------------------------
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# ZENDESK_API_TOKEN=
# MAILCHIMP_API_KEY=
